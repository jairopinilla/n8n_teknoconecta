      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  try {\n    // 1. OBTENER EL TEXTO (Búsqueda Profunda)\n    let textoSucio = \"\";\n    const output = item.json.output;\n\n    // CASO A: Tu estructura actual (Arrays anidados)\n    // output es una lista -> content es una lista -> text\n    if (Array.isArray(output) && output[0]?.content && Array.isArray(output[0].content)) {\n      textoSucio = output[0].content[0].text;\n    } \n    // CASO B: Estructura simple (por si cambia en el futuro)\n    else if (output?.content?.text) {\n      textoSucio = output.content.text;\n    }\n    // CASO C: Output objeto, Content lista\n    else if (output?.content && Array.isArray(output.content)) {\n      textoSucio = output.content[0].text;\n    }\n    \n    // Si no encontramos nada, lanzamos error manual\n    if (!textoSucio) throw new Error(\"No se encontró la ruta del texto JSON\");\n\n    // 2. LIMPIEZA DE SEGURIDAD\n    if (typeof textoSucio === 'string') {\n      textoSucio = textoSucio\n        .replace(/```json/gi, \"\") // Quita etiqueta markdown json\n        .replace(/```/g, \"\")      // Quita comillas de cierre\n        .trim();                  // Quita espacios\n    }\n\n    // 3. PARSEO\n    const datosLimpios = JSON.parse(textoSucio);\n\n    // 4. RETORNO EXITOSO\n    return {\n      json: datosLimpios\n    };\n\n  } catch (error) {\n    return {\n      json: {\n        error: true,\n        mensaje_error: error.message || \"Error al parsear JSON\",\n        // Devolvemos esto para que puedas inspeccionar qué llegó mal\n        debug_output: item.json.output \n      }\n    };\n  }\n});"
        },
