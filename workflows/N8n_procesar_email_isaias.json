    {
      "parameters": {
        "jsCode": "// Iteramos sobre los items entrantes\nfor (const item of $input.all()) {\n  const body = item.json.body;\n\n  // -------------------------------------------------------\n  // 1. LIMPIEZA DEL REMITENTE\n  // -------------------------------------------------------\n  // Priorizamos 'email_remitente', si no existe, usamos 'remitente'\n  const rawRemitente = body.email_remitente || body.remitente || \"\";\n  const remitenteMatch = rawRemitente.match(/<([^>]+)>/);\n  // Si encuentra <email>, usa lo de adentro. Si no, usa el original.\n  const remitenteLimpio = remitenteMatch ? remitenteMatch[1] : rawRemitente;\n\n  // -------------------------------------------------------\n  // 2. LIMPIEZA DEL DESTINATARIO (NUEVO)\n  // -------------------------------------------------------\n  const rawDestinatario = body.email_destinatario || \"\";\n  const destMatch = rawDestinatario.match(/<([^>]+)>/);\n  // Misma lógica: extraer lo que está entre corchetes\n  const destinatarioLimpio = destMatch ? destMatch[1] : rawDestinatario;\n\n  // -------------------------------------------------------\n  // 3. LIMPIEZA DEL CUERPO (Estrategia Anti-Ruido)\n  // -------------------------------------------------------\n  let texto = body.cuerpo_texto || body.cuerpo_html || \"\";\n\n  // A. Eliminar URLs largas\n  texto = texto.replace(/https?:\\/\\/[^\\s]+/g, \" \");\n\n  // B. Eliminar marcadores de imágenes de Gmail\n  texto = texto.replace(/\\[image:[^\\]]+\\]/g, \"\");\n\n  // C. Limpieza cosmética final\n  texto = texto\n    .replace(/\\r\\n/g, \"\\n\")      // Normalizar saltos de línea\n    .replace(/\\n\\s*\\n/g, \"\\n\")   // Eliminar líneas vacías repetidas\n    .replace(/[ \\t]+/g, \" \")     // Eliminar espacios repetidos\n    .trim();\n\n  // -------------------------------------------------------\n  // 4. RETORNO DE DATOS LIMPIOS\n  // -------------------------------------------------------\n  \n  // Guardamos los emails limpios y sin espacios laterales (.trim())\n  item.json.email_remitente_limpio = remitenteLimpio.trim();\n  item.json.email_destinatario_limpio = destinatarioLimpio.trim();\n  \n  // El mensaje depurado\n  item.json.mensaje_depurado = texto;\n  \n  // Pasamos el ID original de Gmail para la base de datos\n  item.json.id_mensaje_gmail = body.id_mensaje_gmail;\n}\n\nreturn $input.all();"
      },
